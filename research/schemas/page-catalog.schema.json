{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://c8x1.github.io/schemas/page-catalog-v1.json",
  "title": "Qwen3-TTS Ascend page catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pages"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug", "title", "summary", "order", "group", "objectives",
          "prerequisites", "sections"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^(index|search|indexes/[a-z0-9-]+|target/[a-z0-9-]+|reference/[a-z0-9-]+|mapping/[a-z0-9-]+|guide/[a-z0-9-]+)\\.html$"
          },
          "title": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "order": {"type": "integer", "minimum": 1},
          "group": {"type": "string", "minLength": 1},
          "track": {
            "type": "string",
            "enum": ["入门教程", "源码深读", "实施路线"]
          },
          "next_slug": {
            "type": "string",
            "pattern": "^(index|search|indexes/[a-z0-9-]+|target/[a-z0-9-]+|reference/[a-z0-9-]+|mapping/[a-z0-9-]+|guide/[a-z0-9-]+)\\.html$"
          },
          "objectives": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "prerequisites": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "title", "blocks"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$"
                },
                "title": {"type": "string", "minLength": 1},
                "blocks": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["paragraph", "call_chain", "table", "source_refs", "index_table"]
                      },
                      "text": {"type": "string"},
                      "state": {
                        "type": "string",
                        "enum": ["verified", "project_claim", "inference", "pending_hardware"]
                      },
                      "evidence_ids": {
                        "type": "array",
                        "items": {"type": "string", "minLength": 1}
                      },
                      "items": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["label", "path", "symbol", "evidence_ids"],
                          "properties": {
                            "label": {"type": "string", "minLength": 1},
                            "path": {"type": "string", "minLength": 1},
                            "symbol": {"type": "string", "minLength": 1},
                            "evidence_ids": {
                              "type": "array",
                              "items": {"type": "string", "minLength": 1}
                            }
                          }
                        }
                      },
                      "headers": {
                        "type": "array",
                        "minItems": 1,
                        "items": {"type": "string"}
                      },
                      "rows": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": {"type": "string"}
                        }
                      },
                      "dataset": {
                        "type": "string",
                        "enum": ["files", "symbols", "configs"]
                      }
                    },
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["type", "text", "state", "evidence_ids"],
                        "properties": {
                          "type": {"type": "string", "const": "paragraph"},
                          "text": {"type": "string"},
                          "state": {
                            "type": "string",
                            "enum": ["verified", "project_claim", "inference", "pending_hardware"]
                          },
                          "evidence_ids": {
                            "type": "array",
                            "items": {"type": "string", "minLength": 1}
                          }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["type", "items"],
                        "properties": {
                          "type": {"type": "string", "const": "call_chain"},
                          "items": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                              "type": "object",
                              "additionalProperties": false,
                              "required": ["label", "path", "symbol", "evidence_ids"],
                              "properties": {
                                "label": {"type": "string", "minLength": 1},
                                "path": {"type": "string", "minLength": 1},
                                "symbol": {"type": "string", "minLength": 1},
                                "evidence_ids": {
                                  "type": "array",
                                  "items": {"type": "string", "minLength": 1}
                                }
                              }
                            }
                          }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["type", "headers", "rows"],
                        "properties": {
                          "type": {"type": "string", "const": "table"},
                          "headers": {
                            "type": "array",
                            "minItems": 1,
                            "items": {"type": "string"}
                          },
                          "rows": {
                            "type": "array",
                            "items": {
                              "type": "array",
                              "items": {"type": "string"}
                            }
                          }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["type", "evidence_ids"],
                        "properties": {
                          "type": {"type": "string", "const": "source_refs"},
                          "evidence_ids": {
                            "type": "array",
                            "minItems": 1,
                            "items": {"type": "string", "minLength": 1}
                          }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["type", "dataset"],
                        "properties": {
                          "type": {"type": "string", "const": "index_table"},
                          "dataset": {
                            "type": "string",
                            "enum": ["files", "symbols", "configs"]
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
